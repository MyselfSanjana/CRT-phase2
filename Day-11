no. of islands

class Solution {
    private:

    void dfs(vector<vector<char>>& grid,int row,int col){
        grid[row][col] = '*';
        if(row > 0 && grid[row-1][col] == '1'){ //up
            dfs(grid,row-1,col);
        }
        if(row+1 < rows && grid[row+1][col] == '1'){ //down
            dfs(grid,row+1,col);
        }
        if(col > 0 && grid[row][col-1] == '1'){ //right
            dfs(grid,row,col-1);
        }
        if(col + 1 < cols && grid[row][col+1] == '1'){ //left
            dfs(grid,row,col+1);
        }
    }
public:
int rows; //total no of rowss...
int cols; //total no of columnss...
    int numIslands(vector<vector<char>>& grid) {
        int islands = 0;
        rows = grid.size();
        cols = grid[0].size(); 
        for(int row = 0;row<rows;row++){ //row = curr row
            for(int col = 0 ; col < cols ; col++ ){ //col = curr col
                if(grid[row][col] == '1'){
                    dfs(grid,row,col);
                    islands++;
                }
            }
        }
        return islands;
    }
};

