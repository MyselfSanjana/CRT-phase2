gfg DFS of graph

class Solution {
	public:
	
	void dfsHelper(vector<vector<int>> & adj, 
  vector<bool> &visited,
  vector<int>&ans,
	int node) {
		visited[node] = true;
		ans.push_back(node);
		
		for (int adjacentNode : adj[node]) {
			if (!visited[adjacentNode]) {
				dfsHelper(adj, visited, ans, adjacentNode);
			}
		}
	}
	vector<int> dfs(vector<vector<int>> & adj) {
		int n = adj.size();
		vector<bool> visited(n, false);
		vector<int> ans;
		
		dfsHelper(adj, visited, ans, 0);
		return ans;
	}
};

