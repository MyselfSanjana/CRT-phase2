bfs of graph

class Solution {
	public:
	vector<int> bfs(vector<vector<int>> & adj) {
		int n = adj.size();
		vector<int> ans;
		vector<bool> visited(n, false);
		queue<int> q;
		
		q.push(0);
		visited[0] = true;
		
		while (!q.empty()) {
			int node = q.front();
			q.pop();
			
			ans.push_back(node);
			for (int adjacentNode : adj[node]) {
				if (!visited[adjacentNode]) {
					visited[adjacentNode] = true;
					q.push(adjacentNode);
				}
			}
		}
		return ans;
	}
};
