online compiler binary search code

#include <iostream>
#include<vector>
using namespace std;

int binarySearch(vector<int> &nums , int target){
        int n = nums.size();
        int low = 0;
        int high = n-1;
        
    while(low<=high){
        int mid = (low+high)/2;
        if(nums[mid] == target){
            return mid;
        }else if(nums[mid] <= target){
            low = mid+1;
        }else{
            high = mid-1;
        }
    }
    return -1;
}
int main(){
    vector<int> nums = {1,2,3,4,5};
    int target = 3;
    int result = binarySearch(nums,target);
    
    if(result == -1){
        cout<<"element not found";
    }else{
        cout<<"element is fount at "<<result;
    }
    return 0;
}
