gfg ceil in a sorted array.

class Solution {
  public:
    int findCeil(vector<int>& arr, int x) {
        int n = arr.size();
        int low = 0;
        int high = n-1;
        int res = -1;
        
        while(low<=high){
            int guess = (low+high)/2;
            if(arr[guess]<x){
                low = guess + 1;
            }else{
                high = guess - 1;
                res = guess;
            }
        }
        return res;
    }
};

