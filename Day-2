leetcode 2149
Rearrange Array Elements by Sign

class Solution {
public:
    vector<int> rearrangeArray(vector<int>& nums) {

        int n = nums.size();
        vector<int> ans(n);
        int pos = 0;
        int neg = 1;
        for(int i = 0; i < n; i++) {
            if(nums[i] > 0) {
                ans[pos] = nums[i];
                pos = pos+2;
            }
            else {
                ans[neg] = nums[i];
                neg = neg+2;
            }
        }
        return ans;
    }
};

TC: O(n)
SC: O(1)



