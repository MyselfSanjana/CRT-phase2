leetcode 198. House Robber

brute force
class Solution {
public:
    int robFrom(vector<int>& nums, int i) {
        if (i >= nums.size())
            return 0;
    
    int rob = nums[i] + robFrom(nums, i + 2);
    int notRob = robFrom(nums, i + 1);
    return max(rob, notRob);
    } 
    int rob(vector<int>& nums) {
    return robFrom(nums, 0);
    }
};

